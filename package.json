{
  "name": "ydy-note-calculator",
  "version": "1.0.0",
  "description": "YDY Not Hesaplama Sistemi - Sınav not hesaplama uygulaması",
  "main": "node_modules/expo/AppEntry.js",
  "author": "Alparslan Soyak",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "eas-build-android": "eas build --platform android",
    "eas-build-all": "eas build"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-native": "0.71.0",
    "expo": "^48.0.0",
    "expo-splash-screen": "~0.18.2",
    "expo-status-bar": "~1.4.4",
    "react-native-safe-area-context": "4.5.0",
    "react-native-screens": "~3.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.0.0",
    "@types/react-native": "~0.71.0",
    "typescript": "^4.9.0"
  },
  "expo": {
    "name": "YDY Not Hesaplama",
    "slug": "ydy-note-calculator",
    "version": "1.0.0",
    "assetBundlePatterns": ["**/*"],
    "platforms": ["ios", "android", "web"],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#a855f7"
      },
      "package": "com.alparslan.ydynote",
      "versionCode": 1,
      "permissions": []
    },
    "ios": {
      "bundleIdentifier": "com.alparslan.ydynote",
      "buildNumber": "1"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "ydy-note-calculator",
    "userInterfaceStyle": "dark",
    "owner": "alparslan"
  },
  "eas": {
    "build": {
      "development": {
        "distribution": "internal",
        "android": {
          "gradleCommand": ":app:assembleDebug"
        }
      },
      "preview": {
        "distribution": "internal",
        "android": {
          "gradleCommand": ":app:assembleRelease"
        }
      },
      "production": {
        "android": {
          "gradleCommand": ":app:bundleRelease"
        }
      }
    }
  }
}
